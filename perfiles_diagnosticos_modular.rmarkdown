cat("  • Identificación de diagnósticos sub-representados (RR ≤ 0.67)\n")
cat("  PENDIENTE: Estandarización por edad\n\n")

cat("FUNCIONES MODULARIZADAS UTILIZADAS:\n")
cat("  • obtener_poblacion_censo() - Denominadores desde censo2017\n")
cat("  • concatenar_diag_cie10() - Descripciones CIE-10 FONASA (español)\n")
cat("  • calcular_perfil_diagnostico() - Tasas y proporciones por diagnóstico\n")
cat("  • comparar_perfiles_po_pg() - Comparación con RR crudo\n")
cat("  • crear_tabla_perfil() - Tablas formateadas estandarizadas\n")
cat("  • graficar_perfil_top() - Gráfico de barras horizontales\n")
cat("  • graficar_diferencias_tasas() - Gráfico divergente de diferencias\n")
cat("  • guardar_tabla_html() - Exportación HTML\n")
cat("  • guardar_multiformato() - Exportación gráficos (PNG, JPG, PDF)\n\n")

cat("- Todos los resultados guardados en: resultados_tesis/perfiles/\n")
cat("- Denominadores: persona-años (población Censo 2017 × 13 años)\n")
cat("- Fórmulas según protocolo (Bonita, 2006)\n\n")

cat("LIMITACIONES METODOLÓGICAS:\n")
cat("  • RR crudos SIN ajuste por edad (ver Sección 3 - pendiente)\n")
cat("  • Población Censo 2017 fija (no hay proyecciones anuales por pertenencia)\n")
cat("  • No se ajusta por otros confusores (región, acceso a salud)\n")
cat("  • Estandarización directa requiere extraer estructura etaria del censo\n\n")

cat("CÓDIGO REDUCIDO:\n")
cat("  Versión original: 471 líneas\n")
cat("  Versión modular: ~330 líneas\n")
cat("  Reducción: ~30% (141 líneas menos)\n")
cat("  Funciones creadas: 5 nuevas funciones en R/perfiles/\n")
```

